// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id        String   @id @default(cuid())
  title     String
  date      String   @default("") // YYYY-MM-DD
  startTime String?
  endTime   String?
  status    String   @default("pending") // "pending", "completed"
  source    String   @default("local") // "local", "google_calendar"
  
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserStat {
  id                    String   @id @default("default_user")
  currentStreak         Int      @default(0)
  lastVisitDate         String   @default("") // YYYY-MM-DD
  lastStreakIncrement   String   @default("") // YYYY-MM-DD
  newsTopic             String   @default("Artificial Intelligence")
  theme                 String   @default("light")
  focusDuration         Int      @default(25)
  silentMode            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model JournalEntry {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String?
  sentiment String   @default("Neutral")
  tags      String   @default("") // Comma separated tags
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("active") // "active", "completed", "archived"
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  referenceId String   @unique // To prevent duplicate alerts for the same event (e.g. "task-123-due")
  title       String
  description String
  type        String   // "meeting", "task_overdue", "task_due_soon"
  timeString  String
  isRead      Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())
}
